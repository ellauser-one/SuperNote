# Optional display name for startup banner (else inferred from CLAUDE.md)
# APP_NAME=SuperNote
# SYSTEM_NAME=SuperNote

# Supabase (server only — never ship service_role to the browser)
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HTTP
PORT=10002
CORS_ORIGINS=http://localhost:10001

# chat service (api → chat trusted context)
CHAT_URL=http://localhost:10003
# Must match chat INTERNAL_SERVICE_TOKEN
INTERNAL_SERVICE_TOKEN=dev-shared-service-token-change-me
