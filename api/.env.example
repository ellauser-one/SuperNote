# ---- api service environment ----
# Copy to .env and fill in real values.

# HTTP
PORT=20001
NODE_ENV=development
SYSTEM_NAME=SuperNote

# CORS (comma-separated)
# dev: NODE_ENV=development 时 CORS 放行 *（通配）；prod: 必须显式设
# NODE_ENV=production 且 CORS_ORIGINS=真实前端域名，否则跨域会被拒绝。
CORS_ORIGINS=http://localhost:20000,http://127.0.0.1:20000

# AI 分类 chat 服务基址（POST ${CHAT_BASE_URL}/v1/classify）
CHAT_BASE_URL=http://localhost:20002

# Supabase (server only — never ship service_role to the browser)
# Dashboard -> Project Settings -> API
