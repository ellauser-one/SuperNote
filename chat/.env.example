# SuperNote chat service — copy to .env and fill secrets.
# Never commit real keys.

PORT=20002
ALLOWED_ORIGINS=http://localhost:20000,http://127.0.0.1:20000

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEFAULT_MODEL=deepseek/deepseek-chat
MAX_STEPS=50
MAX_OUTPUT_TOKENS=393216

# Supabase — JWT 鉴权（与 api 同源项目）
SUPABASE_URL=https://your-project.supabase.co
# 二选一即可（优先 ANON）
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mastra Memory — PostgreSQL 连接串（可选；缺失则 memory=null 降级）
# Supabase pooler 示例：postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=
