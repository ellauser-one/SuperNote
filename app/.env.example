# Supabase (public browser keys only — never put service_role here)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Browser public key (required for auth client)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional legacy alias (used only if VITE_SUPABASE_ANON_KEY is empty)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Business API base URL (app → api with Authorization: Bearer <access_token>)
VITE_API_URL=http://localhost:10002
