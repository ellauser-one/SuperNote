# Supabase (public browser keys only — never put service_role here)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Browser public key (preferred for auth client)
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional legacy alias (used only if PUBLISHABLE_KEY is empty)
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Business API base URL (app host :20000 → api Docker :20001)
VITE_API_BASE_URL=http://localhost:20001

# Chat (Mastra) service — SSE streaming assistant
VITE_CHAT_BASE_URL=http://localhost:20002
