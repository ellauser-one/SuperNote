# SuperNote root env template — copy to .env.local and fill secrets.
# Never commit real keys. .env.local is gitignored.

# ---- shared ----
SYSTEM_NAME=SuperNote
NODE_ENV=development

# ---- app (host Bun/Vite :20000, not in Docker) ----
VITE_API_BASE_URL=http://localhost:20001
VITE_CHAT_BASE_URL=http://localhost:20002
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# ---- api (Docker :20001) ----
API_PORT=20001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ORIGINS=http://localhost:20000,http://127.0.0.1:20000

# ---- chat (host mastra :20002) ----
# 详见 chat/.env.example；本地可在 chat/.env 单独配置
# PORT=20002
# ALLOWED_ORIGINS=http://localhost:20000,http://127.0.0.1:20000
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEFAULT_MODEL=deepseek/deepseek-chat
# MAX_STEPS=50
# MAX_OUTPUT_TOKENS=393216
